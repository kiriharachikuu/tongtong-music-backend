# 服务端口
PORT=3000

# JWT 密钥（请修改为随机字符串）
JWT_SECRET=change-this-to-a-random-string

# JWT 过期天数
JWT_EXPIRES_DAYS=30

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# FFmpeg 路径（可选，留空使用系统 PATH）
FFMPEG_PATH=
FFPROBE_PATH=

# 是否将上传的音频转码为 128kbps MP3
TRANSCODE_TO_MP3=1

# 静态资源路径前缀
STATIC_PREFIX=/uploads

# 存储模式：local（本地）或 s3（AWS S3）
STORAGE_MODE=local
