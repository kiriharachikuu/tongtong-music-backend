# ===== 基础配置 =====
# 服务端口
PORT=3000

# JWT 密钥（请修改为随机字符串）
JWT_SECRET=change-this-to-a-random-string

# JWT 过期天数
JWT_EXPIRES_DAYS=30

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ===== FFmpeg 配置 =====
# FFmpeg 路径（可选，留空使用系统 PATH）
# Debian/Ubuntu: 安装 ffmpeg 后留空即可 (sudo apt install ffmpeg)
# Windows: 填写完整路径，如 D:\ffmpeg\bin\ffmpeg.exe
FFMPEG_PATH=
FFPROBE_PATH=

# 是否将上传的音频转码为 128kbps MP3
TRANSCODE_TO_MP3=1

# ===== 静态资源 =====
# 静态资源路径前缀
STATIC_PREFIX=/uploads

# ===== 存储配置 =====
# 存储模式：local（本地）或 s3（AWS S3/兼容对象存储）
STORAGE_MODE=local

# ===== S3 配置（STORAGE_MODE=s3 时需要）=====
# S3_ENDPOINT=
# S3_REGION=us-east-1
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_FORCE_PATH_STYLE=0
# S3_PRESIGN_EXPIRES=3600
# S3_PLAY_MODE=presigned

# ===== 安全配置 =====
# CORS 白名单（逗号分隔，留空则允许所有来源）
# CORS_ORIGIN=https://example.com,https://www.example.com

# 登录限流（每分钟次数）
# RATE_LIMIT_LOGIN=10

# 上传限流（每分钟次数）
# RATE_LIMIT_UPLOAD=60

# ===== 临时文件 =====
# 音频探测临时文件 TTL（毫秒，默认 30 分钟）
# AUDIO_TEMP_TTL=1800000
